# Queries all open creek-service repos and their open PRs, updates each PR branch
# with main, re-runs failed CI checks, and squash-merges PRs that pass.
# Processes repos in parallel, PRs within each repo sequentially.
#
# Usage: creek_gh_rebuild_prs
# Requires: gh CLI authenticated with creek-service org access

setopt LOCAL_OPTIONS
unsetopt XTRACE

_creek_rebuild_process_pr() {
  local repo="$1" pr_num="$2" title="$3"
  local context="https://github.com/$repo/pull/$pr_num"
  local log() { echo "[$(date '+%H:%M:%S')] [$context] $*" }

  log "START: $title"

  # Ensure branch is up to date with main before doing anything
  local update_out
  if update_out=$(gh api --method PUT "repos/$repo/pulls/$pr_num/update-branch" 2>&1); then
    log "Branch updated with main, waiting for CI to register..."
    sleep 30
  elif echo "$update_out" | grep -qiE "already up.to.date|up to date|no new commits"; then
    log "Branch already up to date with main"
  else
    log "Branch update failed: $update_out"
  fi

  local head_sha=$(gh api "repos/$repo/pulls/$pr_num" --jq '.head.sha' 2>/dev/null)

  # Re-run any failed/cancelled workflow runs
  local rerun_count=0
  while IFS= read -r run_id; do
    log "Re-running failed run $run_id"
    gh api --method POST "repos/$repo/actions/runs/$run_id/rerun-failed-jobs" --silent 2>/dev/null || \
    gh api --method POST "repos/$repo/actions/runs/$run_id/rerun" --silent 2>/dev/null || true
    (( ++rerun_count ))
  done < <(gh api "repos/$repo/actions/runs?head_sha=$head_sha&per_page=100" \
    --jq '.workflow_runs[] | select(.conclusion != null and .conclusion != "success" and .conclusion != "skipped" and .conclusion != "neutral") | .id' 2>/dev/null)

  if (( rerun_count > 0 )); then
    log "Triggered $rerun_count re-run(s), waiting for CI to register..."
    sleep 60
  fi

  # Poll until all checks complete.
  while true; do
    local checks=$(gh pr checks "$pr_num" --repo "$repo" 2>/dev/null)
    local queued=$(echo "$checks" | grep -cE '\s+(pending|queued)\s' || true)
    local running=$(echo "$checks" | grep -cE '\s+in_progress\s' || true)
    local failing=$(echo "$checks" | grep -cE '\s+fail\s' || true)

    if (( queued > 0 && running == 0 )); then
      log "Queued... ($queued queued)"
      sleep 30
      continue
    fi

    if (( queued > 0 || running > 0 )); then
      log "Running... ($running running, $queued queued)"
      sleep 30
      continue
    fi

    if (( failing == 0 )); then
      log "All checks passed! Merging..."
      local merge_out
      if merge_out=$(gh pr merge "$pr_num" --repo "$repo" --squash --delete-branch 2>&1); then
        log "Merged successfully"
      else
        log "Merge failed: $merge_out"
      fi
    else
      log "Checks still failing, skipping (${failing} failures)"
    fi
    return 0
  done
}

_creek_rebuild_check_main() {
  local repo="$1"
  local log() { echo "[$(date '+%H:%M:%S')] [$repo main] $*" }

  local main_sha=$(gh api "repos/$repo/git/ref/heads/main" --jq '.object.sha' 2>/dev/null)
  if [[ -z "$main_sha" ]]; then
    log "Could not resolve main branch SHA, skipping repo"
    return 1
  fi

  # Check if all existing runs on main's HEAD are already green
  local non_green=$(gh api "repos/$repo/actions/runs?head_sha=$main_sha&per_page=100" \
    --jq '.workflow_runs[] | select(.name == "Build") | select(.conclusion != "success" and .conclusion != "skipped" and .conclusion != "neutral") | .id' 2>/dev/null)

  if [[ -z "$non_green" ]]; then
    # Confirm there are actually some successful runs (not just zero runs)
    local any=$(gh api "repos/$repo/actions/runs?head_sha=$main_sha&per_page=100" \
      --jq '[.workflow_runs[] | select(.name == "Build")] | length' 2>/dev/null)
    if [[ "$any" -gt 0 ]]; then
      log "Main Build is green"
      return 0
    fi
  fi

  # Trigger a fresh Build workflow run on main
  local workflow_id=$(gh api "repos/$repo/actions/workflows" \
    --jq '.workflows[] | select(.name == "Build") | .id' 2>/dev/null)

  if [[ -z "$workflow_id" ]]; then
    log "No 'Build' workflow found, skipping repo"
    return 1
  fi

  log "Triggering new main Build..."
  if ! gh api --method POST "repos/$repo/actions/workflows/$workflow_id/dispatches" \
      -f ref=main -f 'inputs[publish_artifacts]=true' --silent 2>/dev/null; then
    log "Failed to trigger main Build, skipping repo"
    return 1
  fi

  log "Main Build triggered, waiting for CI to register..."
  sleep 60

  # Poll main Build workflow
  while true; do
    local statuses=$(gh api "repos/$repo/actions/workflows/$workflow_id/runs?head_sha=$main_sha&per_page=5" \
      --jq '.workflow_runs[] | .status + " " + (.conclusion // "null")' 2>/dev/null)

    local queued=$(echo "$statuses" | grep -cE '^(queued|waiting|pending) ' || true)
    local running=$(echo "$statuses" | grep -cE '^in_progress ' || true)
    local failed=$(echo "$statuses" | grep -vE '(success|skipped|neutral|null)$' | grep -cE ' (failure|cancelled|timed_out|action_required)$' || true)
    local incomplete=$(echo "$statuses" | grep -cE ' null$' || true)

    if (( queued > 0 && running == 0 && incomplete == 0 )); then
      log "Main build queued..."
      sleep 30
      continue
    fi

    if (( running > 0 || incomplete > 0 )); then
      log "Main build running... ($running running, $queued queued)"
      sleep 30
      continue
    fi

    if (( failed > 0 )); then
      log "Main build failed, skipping all PRs"
      return 1
    fi

    log "Main is green"
    return 0
  done
}

_creek_rebuild_process_repo() {
  local repo="$1"
  local prs
  prs=$(gh pr list --repo "$repo" --state open --json number,title \
    --jq '.[] | (.number | tostring) + "\t" + .title' 2>/dev/null \
    | awk 'BEGIN{srand()} {print rand() "\t" $0}' | sort -n | cut -f2-)

  [[ -z "$prs" ]] && return 0

  _creek_rebuild_check_main "$repo" || return 0

  while IFS=$'\t' read -r pr_num title; do
    _creek_rebuild_process_pr "$repo" "$pr_num" "$title"
  done <<< "$prs"
}

echo "Fetching creek-service repos..."
local repos
if ! repos=$(gh repo list creek-service --limit 2000 --no-archived --json nameWithOwner \
    --jq '.[].nameWithOwner' 2>/dev/null); then
  echo "Failed to fetch repos" >&2
  return 1
fi

local repo_count=$(echo "$repos" | wc -l | tr -d ' ')
echo "Processing $repo_count repos in parallel..."

(
  trap 'echo ""; echo "Interrupted — stopping all repo jobs..."; kill 0' INT TERM
  for repo in ${(f)repos}; do
    _creek_rebuild_process_repo "$repo" &
  done
  wait
)

echo ""
echo "Done."
